# === Elasticsearch ===
ES_HOST=http://localhost:9200
ES_INDEX_METRICS=app-metrics
ES_INDEX_ERRORS=apm-errors
ES_INDEX_RUNBOOKS=runbooks
ES_INDEX_INCIDENTS=sentinel-incidents

# === LLM (Free Tier) ===
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# === GitHub (optional, unauthenticated works for public repos) ===
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPO=owner/repo-name

# === Slack (free, use Incoming Webhooks) ===
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_CHANNEL=#incidents

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_CALLBACK_URL=http://localhost:8000

# === Safety ===
SENTINEL_APPROVAL_MODE=strict
ANOMALY_POLL_INTERVAL_SECONDS=60
